{
    "name": "d2r-reimagined-website",
    "description": "An Aurelia 2 client application.",
    "version": "0.1.0",
    "repository": {
        "type": "git",
        "url": "???"
    },
    "license": "UNLICENSED",
    "dependencies": {
        "@tailwindcss/vite": "^4.2.4",
        "aurelia": "2.0.0-rc.1",
        "flowbite": "^4.0.1",
        "tailwindcss": "^4.2.4"
    },
    "type": "module",
    "packageManager": "pnpm@10.33.2",
    "devDependencies": {
        "@aurelia/router": "2.0.0-rc.1",
        "@aurelia/validation-html": "2.0.0-rc.1",
        "@aurelia/vite-plugin": "2.0.0-rc.1",
        "@eslint/js": "^10.0.1",
        "@typescript-eslint/eslint-plugin": "^8.59.0",
        "@typescript-eslint/parser": "^8.59.0",
        "autoprefixer": "^10.5.0",
        "cpy-cli": "^7.0.0",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-cypress": "^6.3.1",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "htmlhint": "^1.9.2",
        "postcss": "^8.5.12",
        "rimraf": "^6.1.3",
        "sass": "^1.99.0",
        "tslib": "^2.8.1",
        "typescript": "^6.0.3",
        "vite": "^7.3.0",
        "vite-plugin-static-copy": "^4.1.0"
    },
    "scripts": {
        "build": "rimraf docs/assets && vite build && cp docs/index.html docs/404.html",
        "dependencies:check": "pnpm dlx npm-check-updates",
        "dependencies:update": "pnpm dlx npm-check-updates -u",
        "dependencies:update:patch": "pnpm dlx npm-check-updates -u --target patch",
        "dependencies:update:minor": "pnpm dlx npm-check-updates -u --target minor",
        "lint": "pnpm run lint:js && pnpm run lint:html",
        "lint:html": "htmlhint -c .htmlhintrc src",
        "lint:js": "eslint src",
        "lint:fix": "eslint src --fix",
        "start": "vite"
    }
}
